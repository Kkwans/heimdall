# Heimdall Docker Compose 环境变量配置
# 使用方法：复制为 .env 文件并修改对应值
# cp .env.example .env

# ── 端口配置 ────────────────────────────────────────────────
# 代理服务端口（AI 请求转发入口）
PROXY_PORT=8888

# 面板服务端口（Dashboard Web UI）
DASHBOARD_PORT=8889

# ── 代理配置 ────────────────────────────────────────────────
# 代理路径前缀（客户端请求路径）
HEIMDALL_PROXY_PATH=/v1/openai/native

# 请求超时时间（秒）
HEIMDALL_TIMEOUT=120

# ── 日志配置 ────────────────────────────────────────────────
# 是否记录完整请求/响应内容（开启后磁盘占用显著增大）
HEIMDALL_DETAIL_LOG=false

# 日志保留天数
HEIMDALL_LOG_BACKUP_DAYS=30
