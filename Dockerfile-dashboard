# Heimdall 面板服务 Dockerfile
# 职责：统计 API、代理管理、Credit API、前端静态文件
# 端口：8889
# 构建：docker build -f Dockerfile-dashboard -t heimdall-dashboard:latest .
#
# 注意：前端在构建前已预构建（npm run build），产物在 frontend/dist/
# 原因：package-lock.json 中的美团内网 npm 镜像 URL 在 Docker 内无法访问

FROM python:3.9-slim

LABEL maintainer="Kkwans"
LABEL description="Heimdall Dashboard Service"

# 安装系统依赖 + Docker CLI
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        gnupg \
        lsb-release && \
    # 安装 Docker CLI
    curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian $(lsb_release -cs) stable" > /etc/apt/sources.list.d/docker.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends docker-ce-cli && \
    # 清理
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app/backend

# 安装 Python 依赖
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制后端代码
COPY backend/ ./

# 复制预构建的前端产物到 ../frontend/dist/
# BASE_DIR = /app/backend/.. = /app → DASHBOARD_DIST_DIR = /app/frontend/dist
COPY frontend/dist/ ../frontend/dist/

# 创建数据和日志目录（可被 volume 挂载覆盖）
RUN mkdir -p /data /logs

# 环境变量：覆盖 config.py 中的 macOS 默认路径
ENV HEIMDALL_DATA_DIR=/data
ENV HEIMDALL_LOG_DIR=/logs
ENV HEIMDALL_PORT=8889
ENV PYTHONUNBUFFERED=1

# 暴露面板端口
EXPOSE 8889

# 健康检查：检测面板端口是否可连接
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import socket; s=socket.socket(); s.settimeout(2); s.connect(('127.0.0.1',8889)); s.close()" || exit 1

# 启动面板服务
CMD ["python", "proxy.py", "--dashboard"]
