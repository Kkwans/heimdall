# Heimdall 面板服务 Dockerfile（多阶段构建）
# 职责：统计 API、代理管理、Credit API、前端静态文件
# 端口：8889
# 构建：docker build -f Dockerfile-dashboard -t heimdall-dashboard:latest .

# ── 阶段 1：构建前端 ──────────────────────────────────────────────
FROM node:20-alpine AS frontend-builder

WORKDIR /build

# 先复制依赖描述文件，利用层缓存
COPY frontend/package.json frontend/package-lock.json ./

# 安装依赖（CI 模式：严格按 lock 文件安装）
RUN npm ci

# 复制前端源码
COPY frontend/ .

# 构建前端（输出到 dist/）
# 注意：xattr 命令在 Alpine 内不存在，但 vite.config.ts 的 strip-provenance 插件已处理
RUN npm run build 2>/dev/null || npx vite build

# ── 阶段 2：运行时 ──────────────────────────────────────────────
FROM python:3.9-slim

LABEL maintainer="Kkwans"
LABEL description="Heimdall Dashboard Service"

WORKDIR /app/backend

# 安装 Python 依赖
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制后端代码
COPY backend/ ./

# 复制前端构建产物到 ../frontend/dist/（与 config.py 的 DASHBOARD_DIST_DIR 对应）
# BASE_DIR = /app/backend/.. = /app → DASHBOARD_DIST_DIR = /app/frontend/dist
COPY --from=frontend-builder /build/dist/ ../frontend/dist/

# 创建数据和日志目录（可被 volume 挂载覆盖）
RUN mkdir -p /data /logs

# 环境变量：覆盖 config.py 中的 macOS 默认路径
ENV HEIMDALL_DATA_DIR=/data
ENV HEIMDALL_LOG_DIR=/logs
ENV HEIMDALL_PORT=8889
ENV PYTHONUNBUFFERED=1

# 暴露面板端口
EXPOSE 8889

# 健康检查：检测面板端口是否可连接
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import socket; s=socket.socket(); s.settimeout(2); s.connect(('127.0.0.1',8889)); s.close()" || exit 1

# 启动面板服务
CMD ["python", "proxy.py", "--dashboard"]
